.bc-btn {
  position: relative;
  display: block;
  width: 100%;
  height: 96rpx;
  box-sizing: border-box;
}

.bc-btn__shadow,
.bc-btn__face {
  border-radius: 999rpx;
}

.bc-btn__shadow {
  position: absolute;
  left: 0;
  right: 0;
  top: 10rpx;
  bottom: 0;
  background: var(--bc-border);
}

.bc-btn__face {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transition: transform 120ms ease;
}

.bc-btn--default .bc-btn__face {
  background: var(--bc-surface);
  color: var(--bc-text);
  border: 2rpx solid var(--bc-border);
}

.bc-btn--primary .bc-btn__face {
  background: var(--bc-brand);
  color: #fff;
}

.bc-btn--danger .bc-btn__face {
  background: var(--bc-danger);
  color: #fff;
}

.bc-btn.is-pressed .bc-btn__face {
  transform: translateY(8rpx);
}

.bc-btn.is-disabled {
  opacity: 0.5;
}
