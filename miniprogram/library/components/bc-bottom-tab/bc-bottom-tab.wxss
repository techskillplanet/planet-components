.bc-tabbar {
  flex: 0 0 auto;
  display: flex;
  background: var(--bc-surface);
  border-top: 2rpx solid var(--bc-border);
  padding: 8rpx 24rpx calc(8rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.bc-tabbar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: var(--bc-muted);
  font-size: 22rpx;
  padding: 8rpx 0;
}

.bc-tabbar__item.is-active {
  color: var(--bc-brand);
  font-weight: 700;
}

.bc-tabbar__icon {
  font-size: 34rpx;
  line-height: 1.2;
}
